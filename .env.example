# App
NODE_ENV=development
APP_PUBLIC_URL=http://localhost:3000
PORT=3001

# CORS
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-CSRF-Token
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_MAX_AGE_SECONDS=600

# Database
DB_HOST=your-db-host
DB_PORT=your-db-port
DB_USER=your-db-user
DB_PASSWORD=your-postgres-password
DB_NAME=your-db-name
DB_SSL=false
DB_LOGGING=false

# Auth (JWT)
JWT_SECRET=change-me-with-a-long-random-secret
JWT_EXPIRES_IN=3600s
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Refresh cookie
AUTH_REFRESH_COOKIE_NAME=wegox_refresh
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_SECURE=false

# CSRF
AUTH_CSRF_COOKIE_NAME=wegox_csrf
AUTH_CSRF_COOKIE_PATH=/
AUTH_CSRF_HEADER_NAME=x-csrf-token

# Captcha
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_EXPECTED_HOSTNAME=localhost
TURNSTILE_TIMEOUT_MS=5000
TURNSTILE_LOGIN_ACTION=login
TURNSTILE_BOOKING_ACTION=booking_create

# Auth security
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_FAILED_RESET_MINUTES=30

# Rate limit
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# Seed SuperAdmin
SUPERADMIN_NAME=Admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!

# AWS S3 (tenant branding assets)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_PUBLIC_BASE_URL=https://cdn.example.com
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token
AWS_S3_FORCE_PATH_STYLE=false

# Email notifications
MAIL_ENABLED=false
MAIL_FROM_EMAIL=notifications@example.com
MAIL_FROM_NAME=Wegox Booking
MAIL_REPLY_TO_EMAIL=support@example.com
MAIL_ASSET_BASE_URL=https://cdn.example.com
MAIL_RESEND_MIN_INTERVAL_MS=650
RESEND_API_KEY=re_your_resend_api_key
