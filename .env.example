# App
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-CSRF-Token
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_MAX_AGE_SECONDS=600

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=booking_system
DB_SSL=false
DB_LOGGING=false

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600s
JWT_ACCESS_EXPIRES_IN=3600s
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
AUTH_REFRESH_COOKIE_NAME=weegox_refresh
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_SECURE=
AUTH_CSRF_COOKIE_NAME=weegox_csrf
AUTH_CSRF_HEADER_NAME=x-csrf-token
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_EXPECTED_HOSTNAME=localhost
TURNSTILE_TIMEOUT_MS=5000
TURNSTILE_LOGIN_ACTION=login
TURNSTILE_BOOKING_ACTION=booking_create
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_FAILED_RESET_MINUTES=30

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# AWS S3 (tenant branding assets)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_FORCE_PATH_STYLE=false
